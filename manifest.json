{
  "manifest_version": 3,
  "name": "linksweeper",
  "description": "Prototype URL cleaner and redirector for stripping trackers and routing known domains.",
  "version": "0.1.0",
  "minimum_chrome_version": "121",
  "permissions": [
    "activeTab",
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "linksweeper"
  },
  "options_page": "src/options.html"
}
