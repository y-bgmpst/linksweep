{
  "manifest_version": 3,
  "name": "LinkSweep",
  "description": "Small URL cleaner and redirector for stripping tracking parameters and routing known domains.",
  "version": "0.0.3",
  "minimum_chrome_version": "121",
  "permissions": [
    "activeTab",
    "declarativeNetRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "LinkSweep"
  },
  "options_page": "src/options.html"
}
